CC=emcc
CXX = em++

CFLAGS+=-sDISABLE_EXCEPTION_CATCHING=1
CFLAGS+=-DIMGUI_DISABLE_FILE_FUNCTIONS

CPPFLAGS+=-sDISABLE_EXCEPTION_CATCHING=1
CPPFLAGS+=-DIMGUI_DISABLE_FILE_FUNCTIONS
CPPFLAGS+=--use-port=contrib.glfw3

LDFLAGS+=-sUSE_WEBGL2=1
LDFLAGS+=--use-port=contrib.glfw3
LDFLAGS+=-sASSERTIONS=1
LDFLAGS+=-sNO_FILESYSTEM=1
LDFLAGS+=-sALLOW_MEMORY_GROWTH=1
LDFLAGS+=-sWASM=1
LDFLAGS+=-sENVIRONMENT=web
LDFLAGS+=--pre-js web_pre.js
LDFLAGS+=-sDISABLE_EXCEPTION_CATCHING=1
LDFLAGS+=-sEXPORTED_RUNTIME_METHODS=ccall,cwrap
LDFLAGS+=-sEXPORTED_FUNCTIONS=_main

ARTIFACT="klejne.js"
include Makefile.common
